---
# tests/.clang-tidy — RELAXED profile for test code
# Applies to: tests/
# Policy:     CLAUDE.md §9 compliance table — tests/ exemptions apply.
#             Rule 3 (no malloc), Rule 5 (assertion density), Rule 9 (fn pointers),
#             and no-STL are explicitly waived for test code.
# Run via: make lint

Checks: >
  bugprone-*,
  clang-analyzer-*,
  misc-unused-parameters,
  modernize-use-nullptr,
  modernize-use-override,
  performance-*,
  portability-*,
  readability-braces-around-statements,
  readability-misleading-indentation,
  readability-redundant-control-flow,
  readability-simplify-boolean-expr,
  -bugprone-easily-swappable-parameters,
  -bugprone-macro-parentheses,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-no-malloc,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-cstyle-cast,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -misc-no-recursion,
  -modernize-use-auto,
  -modernize-use-trailing-return-type,
  -readability-function-cognitive-complexity,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-uppercase-literal-suffix

WarningsAsErrors: '*'

# Report findings in both project source and test headers.
HeaderFilterRegex: '(src|tests)/.*'
