# parse_peer_ip/parse_peer_port/parse_server_port receive argv from main() which
# is typed char* argv[] per the C++ standard. Changing to char* const is correct
# but cppcheck may still flag depending on exact version behavior.
constParameter:src/app/Client.cpp
constParameter:src/app/Server.cpp

# Justification: normalCheckLevelMaxBranches -- cppcheck informational note that it is
# limiting branch analysis depth for performance in DeliveryEngine and Serializer.
# Not a code defect; use --check-level=exhaustive to remove, at significant cost.
# Pre-existing analysis limitation. Deviation: cppcheck performance trade-off.
normalCheckLevelMaxBranches

# Justification: misra-c2012-12.3 (comma operator) -- the cppcheck misra addon applies
# MISRA C:2012 rule 12.3 to C++ constructor member-initializer lists, which is a false
# positive. Constructor initializer lists use commas as separators, not the comma operator.
# This project targets MISRA C++:2023, not MISRA C:2012; C++ initializer lists are
# explicitly permitted and have no equivalent restriction in MISRA C++:2023.
misra-c2012-12.3

# Justification: oppositeInnerCondition -- NEVER_COMPILED_OUT_ASSERT(cond) expands
# to if (!(cond)) { ... }, which cppcheck identifies as never-true when cond is the
# same as the enclosing if-branch guard. These assertions intentionally document branch
# invariants per Power of 10 Rule 5. Raw assert() had built-in cppcheck awareness and
# suppressed this; NEVER_COMPILED_OUT_ASSERT does not. Deviation: false positive from
# macro expansion opacity.
oppositeInnerCondition:src/core/RetryManager.cpp
oppositeInnerCondition:src/platform/SocketUtils.cpp

# Justification: arrayIndexOutOfBoundsCond -- NEVER_COMPILED_OUT_ASSERT(i < BOUND)
# expands to if (!(i < BOUND)) { ... }, causing cppcheck to hypothesize the path where
# i >= BOUND, then flag the subsequent array access delayed[i] as out-of-bounds. In
# reality, the macro aborts (debug) or returns (production) before that access.
# The loop bound guarantees i < BOUND; the assertion is a redundant safety net per
# Power of 10 Rule 5. Raw assert() suppressed this internally. Deviation: false positive
# from macro expansion making the abort-path visible to cppcheck's flow analysis.
arrayIndexOutOfBoundsCond:src/platform/TcpBackend.cpp
arrayIndexOutOfBoundsCond:src/platform/UdpBackend.cpp
arrayIndexOutOfBoundsCond:src/platform/LocalSimHarness.cpp
arrayIndexOutOfBoundsCond:src/core/ReassemblyBuffer.cpp
arrayIndexOutOfBoundsCond:src/platform/TlsTcpBackend.cpp
arrayIndexOutOfBoundsCond:src/platform/DtlsUdpBackend.cpp
arrayIndexOutOfBoundsCond:src/core/RequestReplyEngine.cpp

# Justification: nullPointerRedundantCheck -- NEVER_COMPILED_OUT_ASSERT(ptr != nullptr)
# expands to if (!(ptr != nullptr)) { abort/log }, causing cppcheck to hypothesize the
# path where ptr == nullptr, then flag the subsequent dereference as a null pointer
# dereference. In reality, the macro aborts (debug) or resets (production) before the
# dereference. The assertion is a mandatory precondition guard per Power of 10 Rule 5.
# Raw assert() suppressed this internally. Deviation: false positive from macro expansion
# making the abort-path visible to cppcheck's flow analysis.
nullPointerRedundantCheck:src/core/DeliveryEngine.cpp
nullPointerRedundantCheck:src/core/RequestReplyEngine.cpp
nullPointerRedundantCheck:src/platform/ImpairmentConfigLoader.cpp
nullPointerRedundantCheck:src/platform/TlsTcpBackend.cpp
nullPointerRedundantCheck:src/platform/DtlsUdpBackend.cpp
nullPointerRedundantCheck:src/platform/SocketUtils.hpp

# Justification: uninitMemberVar / uninitMemberVarPrivate -- these classes use an
# explicit init() pattern (F-Prime / MISRA C++:2023 style) instead of constructor
# initialization. Members are fully initialized by init() before any other method
# is called; m_initialized guards all runtime methods via NEVER_COMPILED_OUT_ASSERT.
# noConstructor suppresses the missing-constructor warning; these suppress the
# complementary uninitialized-member warnings for the same design pattern.
# Deviation: F-Prime init() idiom; logged with noConstructor deviation above.
uninitMemberVar:src/core/DeliveryEngine.hpp
uninitMemberVarPrivate:src/core/AckTracker.hpp
uninitMemberVarPrivate:src/core/RetryManager.hpp
uninitMemberVarPrivate:src/core/RequestReplyEngine.hpp

